APP_NAME=NY_OPEN_FVG_BOT
ENVIRONMENT=development

# Local quick start uses SQLite. For Postgres use:
# DATABASE_URL=postgresql+psycopg2://trading_user:trading_password@localhost:5432/trading_bot
DATABASE_URL=sqlite:///./trading_bot.db

TRADING_MODE=PAPER
LIVE_TRADING_CONFIRM=false

DEFAULT_SYMBOL=NAS100
DEFAULT_TIMEZONE=America/New_York

RISK_PER_TRADE_PERCENT=0.5
MAX_TRADES_PER_DAY=1
MAX_LOSSES_PER_DAY=2
MIN_RISK_REWARD=2.0

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

MT5_ENABLED=false
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=
